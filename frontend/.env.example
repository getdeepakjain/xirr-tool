# Absolute URL of the FastAPI backend.
#
# LOCAL DEV:   leave EMPTY. API calls are same-origin and go through the Vite
#              dev proxy (see vite.config.ts), and the "Continue with Google"
#              link resolves against the proxy too.
#
# PRODUCTION:  set to your deployed backend origin (no trailing slash), e.g.
#              https://xirr-backend.onrender.com
#              On Vercel, add this as an Environment Variable named
#              VITE_BACKEND_URL (Production + Preview) instead of committing it.
VITE_BACKEND_URL=
