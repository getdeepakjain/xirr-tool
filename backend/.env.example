# Copy this file to `.env` and fill in the values.

# Secret used to sign JWT access tokens. Generate a strong random string, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Access token lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database URL.
#   Local dev / persistent-disk hosts (SQLite):
#     sqlite:///./data/portfolio.sqlite3          (relative, local dev)
#     sqlite:////data/portfolio.sqlite3           (absolute, Fly.io volume)
#     sqlite:////var/data/portfolio.sqlite3       (absolute, Render disk)
#   Managed Postgres (Neon/Supabase/Render/Railway) — driver is bundled; a plain
#   postgres://... or postgresql://... URL works and is auto-adapted to psycopg v3:
#     postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=sqlite:///./data/portfolio.sqlite3

# CORS: comma-separated list of allowed frontend origins (NO trailing slash).
#   Local dev:  http://localhost:5173,http://127.0.0.1:5173
#   Production: add your Vercel URL, e.g. https://your-app.vercel.app
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Google OAuth (optional; login with Google) ----
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: <BACKEND_BASE_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public base URL of THIS backend (used to build the OAuth callback URL).
#   Local dev:  http://localhost:8000
#   Production: your backend host URL, e.g. https://xirr-backend.onrender.com
BACKEND_BASE_URL=http://localhost:8000
# Where to send the user after a successful Google login (your frontend).
#   Local dev:  http://localhost:5173
#   Production: your Vercel URL, e.g. https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173
