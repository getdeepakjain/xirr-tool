# Copy this file to `.env` and fill in the values.

# Secret used to sign JWT access tokens. Generate a strong random string, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Access token lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# SQLite database URL (file lives under backend/data/)
DATABASE_URL=sqlite:///./data/portfolio.sqlite3

# CORS: comma-separated list of allowed frontend origins
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Google OAuth (optional; login with Google) ----
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: <BACKEND_BASE_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BACKEND_BASE_URL=http://localhost:8000
# Where to send the user after a successful Google login
FRONTEND_URL=http://localhost:5173
